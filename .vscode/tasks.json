{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:/msys64/mingw64/bin/g++.exe",
            "args": [
                "-g",
                "-std=c++17",
                "-I${workspaceFolder}/include",
                "-L${workspaceFolder}/lib",
                "${workspaceFolder}/src/main.cpp",
                "${workspaceFolder}/src/glad.c",
                "${workspaceFolder}/src/shaderclass.cpp",
                "${workspaceFolder}/src/vao.cpp",
                "${workspaceFolder}/src/vbo.cpp",
                "${workspaceFolder}/src/ebo.cpp",
                "${workspaceFolder}/src/stb.cpp",
                "${workspaceFolder}/src/texture.cpp",
                "${workspaceFolder}/src/perlin.cpp",
                "-lglfw3dll",
                "-o",
                "${workspaceFolder}/cutable.exe"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "new"    
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "compiler: C:/msys64/mingw64/bin/g++.exe"
        }
    ]
}